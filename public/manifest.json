{
	"manifest_version": 3,
	"name": "RecGrab — Recreation.gov Availability Helper",
	"version": "0.1.0",
	"description": "Filter Recreation.gov detailed-availability grids to the entry points you want, auto-set group size, and assist clicking open dates.",
	"permissions": ["storage", "activeTab", "scripting", "clipboardWrite"],
	"host_permissions": ["https://www.recreation.gov/*"],
	"action": {
		"default_title": "RecGrab",
		"default_popup": "src/popup/popup.html"
	},
	"background": {
		"service_worker": "src/background/service-worker.js",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["https://www.recreation.gov/*"],
			"run_at": "document_idle",
			"css": ["src/content/content.css"],
			"js": [
				"src/content/core.js",
				"src/content/filter.js",
				"src/content/autofill.js",
				"src/content/autograb.js",
				"src/content/panel.js",
				"src/content/main.js"
			]
		}
	],
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	}
}
